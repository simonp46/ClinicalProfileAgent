# ----- Global -----
COMPOSE_PROJECT_NAME=therapy-meet-copilot

# ----- API -----
API_HOST=0.0.0.0
API_PORT=8000
API_ENV=development
API_LOG_LEVEL=INFO
API_CORS_ORIGINS=["http://localhost:3000"]
WEB_APP_URL=http://localhost:3000
SECRET_KEY=change-me-super-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
CSRF_ENABLED=true
CSRF_COOKIE_NAME=tmc_csrf
REFRESH_COOKIE_NAME=tmc_refresh
ENCRYPTION_KEY=

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=therapy_copilot
POSTGRES_USER=therapy
POSTGRES_PASSWORD=therapy
DATABASE_URL=postgresql+psycopg://therapy:therapy@postgres:5432/therapy_copilot

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=60
OPENAI_MAX_RETRIES=3
PROMPT_VERSION=v1

GOOGLE_PROJECT_ID=
GOOGLE_WORKSPACE_EVENTS_AUDIENCE=
GOOGLE_WEBHOOK_SHARED_SECRET=
GOOGLE_SERVICE_ACCOUNT_FILE=
# Optional fallback if the therapist profile does not define google_account_email.
GOOGLE_IMPERSONATED_USER=
GOOGLE_DOCS_OUTPUT_FOLDER_ID=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/profile/google/callback
# Enable to fetch real Meet transcripts with the therapist's Google Workspace account.
GOOGLE_TRANSCRIPT_FETCH_ENABLED=true

MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_TENANT_ID=common
MICROSOFT_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/profile/microsoft/callback

ARTIFACTS_DIR=/app/data/artifacts
# Free SMTP option (Brevo): create SMTP credentials in Brevo and then set USE_MOCK_EMAIL=false.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=therapy-meet-copilot
SMTP_USE_TLS=true
SMTP_USE_SSL=false
USE_MOCK_EMAIL=true
PASSWORD_RESET_CODE_EXPIRE_MINUTES=15
USE_MOCK_OPENAI=true
# Set to false to use real Google Workspace APIs via therapist OAuth or delegated impersonation.
USE_MOCK_GOOGLE=true

OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=therapy-meet-copilot-api

# ----- Web -----
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=therapy-meet-copilot
